# Server environment variables

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Server port (optional, defaults to 3001)
PORT=3001

# Environment (development/production)
NODE_ENV=development

# CORS origins (comma-separated, optional)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: force Facebook/Instagram OAuth to use a specific Page ID
# Example: EarthCure page ID
FB_PAGE_ID=

# WhatsApp Cloud API (assisted WhatsApp Status workflow)
# Notes:
# - This does NOT publish a Status automatically; it sends you a WhatsApp message with media+caption.
# - WA_DEFAULT_RECIPIENT_PHONE (or legacy WA_RECIPIENT_PHONE) is a fallback recipient.
# - For audience/user-specific sends, pass recipient_phone in the API payload or scheduled post.
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_DEFAULT_RECIPIENT_PHONE=
WA_RECIPIENT_PHONE=
WA_API_VERSION=v19.0

# Optional: template fallback (use if you may message outside 24h session)
WA_TEMPLATE_NAME=
WA_TEMPLATE_LANGUAGE=en_US

# Assisted confirmation flow (template prompt -> user confirms -> final send)
WA_ASSISTED_CONFIRMATION_ENABLED=true
WA_WEBHOOK_VERIFY_TOKEN=
# Shared secret required for Earthcure-forwarded inbound webhook auth header:
# x-content-flow-forward-token: <CONTENT_FLOW_FORWARD_TOKEN>
CONTENT_FLOW_FORWARD_TOKEN=
# Earthcure outbound bridge for confirmation prompts
EARTHCURE_WHATSAPP_SEND_URL=https://www.earthcurebiodiesel.com/.netlify/functions/whatsapp-send-content-flow
# Optional timeout override; clamped to 5000-8000ms
EARTHCURE_WHATSAPP_TIMEOUT_MS=7000
# Optional custom prompt text placeholders:
# {caption} {publish_date} {publish_time} {publish_date_line} {publish_time_line}
WA_ASSISTED_CONFIRMATION_PROMPT_TEXT=
# How long (ms) before a pending prompt operation is considered stale and retryable
WA_ASSISTED_CONFIRMATION_PENDING_STALE_MS=120000
# Optional verification template trigger (used by UI "Send verification template" button)
# Defaults to hello_world / en_US when omitted.
WA_VERIFICATION_TEMPLATE_NAME=hello_world
WA_VERIFICATION_TEMPLATE_LANGUAGE=en_US
WA_CONFIRMATION_TEMPLATE_NAME=
WA_CONFIRMATION_TEMPLATE_LANGUAGE=en_US
# Confirmation template body parameter behavior:
# - WA_CONFIRMATION_BODY_MODE=caption sends a single {caption} parameter by default.
# - WA_CONFIRMATION_BODY_MODE=none sends no body parameters.
# - WA_CONFIRMATION_BODY_PARAMS lets you pass explicit pipe-separated params.
#   Supported placeholders: {caption} {publish_date} {publish_time}
WA_CONFIRMATION_BODY_MODE=caption
WA_CONFIRMATION_BODY_PARAMS=
# Optional map for quick-reply button payload variables: "0:CF_CONFIRM_YES,1:CF_CONFIRM_NO"
WA_CONFIRM_BUTTON_PAYLOAD_MAP=
WA_CONFIRM_YES_PAYLOAD=CF_CONFIRM_YES
WA_CONFIRM_YES_BUTTON_INDEX=0
# If template params mismatch (132000), retry with plain template (no components)
WA_CONFIRMATION_TEMPLATE_RETRY_PLAIN=true
# Optional comma-separated extra reply tokens/IDs from template buttons.
# Example: WA_CONFIRM_AFFIRMATIVE_TOKENS=appointment_confirm,confirm_appointment
#          WA_CONFIRM_NEGATIVE_TOKENS=appointment_cancel,cancel_appointment
WA_CONFIRM_AFFIRMATIVE_TOKENS=
WA_CONFIRM_NEGATIVE_TOKENS=
