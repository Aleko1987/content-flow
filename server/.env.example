# Server environment variables

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Server port (optional, defaults to 3001)
PORT=3001

# Environment (development/production)
NODE_ENV=development

# CORS origins (comma-separated, optional)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: force Facebook/Instagram OAuth to use a specific Page ID
# Example: EarthCure page ID
FB_PAGE_ID=

# WhatsApp Cloud API (assisted WhatsApp Status workflow)
# Notes:
# - This does NOT publish a Status automatically; it sends you a WhatsApp message with media+caption.
# - WA_DEFAULT_RECIPIENT_PHONE (or legacy WA_RECIPIENT_PHONE) is a fallback recipient.
# - For audience/user-specific sends, pass recipient_phone in the API payload or scheduled post.
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_DEFAULT_RECIPIENT_PHONE=
WA_RECIPIENT_PHONE=
WA_API_VERSION=v19.0

# Optional: template fallback (use if you may message outside 24h session)
WA_TEMPLATE_NAME=
WA_TEMPLATE_LANGUAGE=en_US

# Assisted confirmation flow (template prompt -> user confirms -> final send)
WA_ASSISTED_CONFIRMATION_ENABLED=true
WA_WEBHOOK_VERIFY_TOKEN=
# Shared secret required for Earthcure-forwarded inbound webhook auth header:
# x-content-flow-forward-token: <CONTENT_FLOW_FORWARD_TOKEN>
CONTENT_FLOW_FORWARD_TOKEN=
# Optional verification template trigger (used by UI "Send verification template" button)
# Defaults to hello_world / en_US when omitted.
WA_VERIFICATION_TEMPLATE_NAME=hello_world
WA_VERIFICATION_TEMPLATE_LANGUAGE=en_US
WA_CONFIRMATION_TEMPLATE_NAME=
WA_CONFIRMATION_TEMPLATE_LANGUAGE=en_US
WA_CONFIRM_YES_PAYLOAD=CF_CONFIRM_YES
WA_CONFIRM_YES_BUTTON_INDEX=0
